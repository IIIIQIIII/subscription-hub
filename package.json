{
  "name": "subscription-hub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A local subscription command center for humans and agents.",
  "bin": {
    "subhub": "./bin/subhub.js"
  },
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,magenta \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "node src/server/index.js",
    "dev:web": "vite --host 0.0.0.0 --port 5177",
    "cli": "node bin/subhub.js",
    "build": "vite build",
    "start": "NODE_ENV=production node src/server/index.js",
    "check": "npm run build && node bin/subhub.js summary"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.109.0",
    "@vitejs/plugin-react": "^5.0.0",
    "commander": "^14.0.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^7.0.0",
    "zod": "^4.0.0"
  }
}
